<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#2563eb">
<link rel="icon" type="image/x-icon" href="/favicon.ico?v=2">
<link rel="icon" type="image/png" href="/favicon.png?v=2">
<title>Phrasly — Make Your AI Writing Completely Undetectable</title>
<meta name="description" content="Humanize AI-generated text instantly. Bypass Turnitin, GPTZero & more. Trusted by 1M+ writers. Try Phrasly free today at phrasly.co.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --blue:        #2563eb;
    --blue-light:  #3b82f6;
    --blue-pale:   #eff6ff;
    --blue-soft:   #dbeafe;
    --blue-mid:    #93c5fd;
    --blue-deep:   #1e40af;
    --white:       #ffffff;
    --off-white:   #f8faff;
    --ink:         #0d1117;
    --ink-mid:     #374151;
    --ink-light:   #6b7280;
    --border:      #e5e7eb;
    --dark:        #111827;
    --dark-mid:    #1f2937;
    --heading:     'Fraunces', serif;
    --body:        'DM Sans', sans-serif;
  }
  html { scroll-behavior: smooth; }
  body { font-family: var(--body); color: var(--ink); background: var(--white); overflow-x: hidden; }

  /* ── COUNTDOWN BAR ── */
  .countdown-bar {
    background: var(--blue); padding: .65rem 2rem;
    display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap;
  }
  .countdown-bar p { color: #fff; font-size: .82rem; font-weight: 500; }
  .countdown-bar p strong { color: var(--blue-soft); }
  .countdown-units { display: flex; gap: .4rem; align-items: center; }
  .cdu { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.35); border-radius: 5px; padding: .2rem .5rem; min-width: 38px; text-align: center; }
  .cdu-num { font-family: var(--heading); font-size: 1rem; font-weight: 700; color: #fff; line-height: 1; display: block; }
  .cdu-label { font-size: .55rem; color: rgba(255,255,255,0.75); text-transform: uppercase; letter-spacing: .05em; }
  .cdu-sep { color: rgba(255,255,255,0.6); font-weight: 700; }
  .cd-btn { background: #fff; color: var(--blue-deep); font-family: var(--body); font-size: .8rem; font-weight: 700; padding: .3rem .9rem; border-radius: 5px; text-decoration: none; transition: opacity .2s; white-space: nowrap; }
  .cd-btn:hover { opacity: .88; }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,0.97); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2.5rem; display: flex; align-items: center; justify-content: space-between; height: 64px;
  }
  .nav-logo { font-family: var(--heading); font-size: 1.5rem; font-weight: 700; color: var(--ink); text-decoration: none; display: flex; align-items: center; gap: .4rem; }
  .nav-logo .dot { width: 8px; height: 8px; background: var(--blue); border-radius: 50%; display: inline-block; margin-bottom: 2px; }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { font-size: .88rem; font-weight: 500; color: var(--ink-mid); text-decoration: none; transition: color .2s; }
  .nav-links a:hover { color: var(--blue); }
  .nav-btns { display: flex; gap: .8rem; align-items: center; }
  .nav-login { font-size: .88rem; font-weight: 500; color: var(--ink-mid); text-decoration: none; }
  .nav-cta { background: var(--blue); color: #fff; padding: .5rem 1.3rem; border-radius: 7px; font-family: var(--body); font-size: .88rem; font-weight: 600; text-decoration: none; transition: background .2s, transform .15s; display: inline-block; }
  .nav-cta:hover { background: var(--blue-light); transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    padding: 80px 2.5rem 70px; text-align: center;
    background: var(--white); position: relative; overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(37,99,235,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--blue-pale); border: 1px solid var(--blue-soft);
    color: var(--blue-deep); border-radius: 100px;
    padding: .3rem .9rem; font-size: .76rem; font-weight: 600;
    letter-spacing: .05em; margin-bottom: 2rem; text-transform: uppercase;
  }
  .hero-eyebrow-dot { width: 5px; height: 5px; background: var(--blue); border-radius: 50%; }
  .hero h1 {
    font-family: var(--heading); font-weight: 800;
    font-size: clamp(2.6rem, 6vw, 5rem);
    color: var(--ink); line-height: 1.08;
    max-width: 860px; margin: 0 auto 1.5rem;
    letter-spacing: -0.03em;
  }
  .hero h1 em { font-style: italic; color: var(--blue); }
  .hero > p {
    font-size: clamp(1rem, 2vw, 1.15rem); color: var(--ink-light);
    max-width: 520px; margin: 0 auto 2.5rem;
    font-weight: 400; line-height: 1.7;
  }
  .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1rem; }
  .btn-primary {
    background: var(--blue); color: #fff;
    padding: .9rem 2.2rem; border-radius: 9px;
    font-family: var(--body); font-size: 1rem; font-weight: 600;
    text-decoration: none; transition: background .2s, transform .15s, box-shadow .2s;
    display: inline-block; box-shadow: 0 4px 20px rgba(37,99,235,0.3);
  }
  .btn-primary:hover { background: var(--blue-light); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,99,235,0.4); }
  .btn-outline {
    background: #fff; color: var(--ink);
    padding: .9rem 2.2rem; border-radius: 9px;
    border: 1.5px solid var(--border);
    font-family: var(--body); font-size: 1rem; font-weight: 500;
    text-decoration: none; transition: all .2s; display: inline-block;
  }
  .btn-outline:hover { border-color: var(--blue); color: var(--blue); }
  .hero-note { font-size: .8rem; color: var(--ink-light); }

  /* HERO AVATARS */
  .hero-social { display: flex; align-items: center; justify-content: center; gap: 1rem; margin: 2rem 0; }
  .avatar-stack { display: flex; }
  .avatar-stack img, .avatar { width: 36px; height: 36px; border-radius: 50%; border: 2px solid #fff; margin-left: -8px; background: var(--blue-soft); display: flex; align-items: center; justify-content: center; font-family: var(--heading); font-size: .8rem; font-weight: 700; color: var(--blue-deep); overflow: hidden; }
  .avatar-stack .avatar:first-child { margin-left: 0; }
  .hero-social-text { font-size: .85rem; color: var(--ink-mid); }
  .hero-social-text strong { color: var(--ink); font-weight: 600; }
  .hero-stars { color: var(--blue); font-size: .85rem; }

  /* ── PRODUCT MOCKUP ── */
  .mockup-wrap {
    max-width: 900px; margin: 0 auto 0;
    background: var(--off-white); border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);
    position: relative; z-index: 1;
  }
  .mockup-bar { background: #fff; padding: .65rem 1rem; display: flex; align-items: center; gap: .5rem; border-bottom: 1px solid var(--border); }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background: #ff5f57; } .dot-y { background: #ffbd2e; } .dot-g { background: #28c840; }
  .mockup-inner { display: grid; grid-template-columns: 1fr 1fr; min-height: 260px; }
  .mockup-panel { padding: 1.5rem; }
  .mockup-panel:first-child { border-right: 1px solid var(--border); }
  .panel-label { font-size: .7rem; font-weight: 600; color: var(--ink-light); text-transform: uppercase; letter-spacing: .08em; margin-bottom: .8rem; display: flex; align-items: center; gap: .4rem; }
  .panel-label::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--ink-light); display: block; }
  .panel-label.human::before { background: var(--blue); }
  .ai-text { font-size: .82rem; color: var(--ink-light); line-height: 1.7; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: .8rem; }
  .ai-text mark { background: rgba(239,68,68,0.12); color: #dc2626; border-radius: 3px; padding: 0 2px; }
  .human-text { font-size: .82rem; color: var(--ink); line-height: 1.7; background: var(--blue-pale); border: 1px solid var(--blue-soft); border-radius: 8px; padding: .8rem; }
  .human-text mark { background: rgba(37,99,235,0.12); color: var(--blue-deep); border-radius: 3px; padding: 0 2px; }
  .detector-row { display: flex; align-items: center; justify-content: space-between; padding: .5rem .7rem; border-radius: 7px; background: #fff; border: 1px solid var(--border); margin-top: .6rem; font-size: .75rem; }
  .detector-name { font-weight: 600; color: var(--ink-mid); }
  .detector-pass { color: var(--blue); font-weight: 700; display: flex; align-items: center; gap: .3rem; }
  .detector-fail { color: #dc2626; font-weight: 700; display: flex; align-items: center; gap: .3rem; }
  .progress-bar { height: 4px; border-radius: 100px; background: var(--border); overflow: hidden; margin-top: .3rem; }
  .progress-fill { height: 100%; border-radius: 100px; background: var(--blue); }

  /* ── LOGOS ── */
  .logos-strip { background: var(--white); padding: 2.5rem 2.5rem; border-bottom: 1px solid var(--border); text-align: center; }
  .logos-strip p { font-size: .78rem; font-weight: 600; color: var(--ink-light); text-transform: uppercase; letter-spacing: .1em; margin-bottom: 1.5rem; }
  .logos-row { display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; }
  .logo-item { font-family: var(--heading); font-size: 1.1rem; font-weight: 700; color: #d1d5db; letter-spacing: -.02em; }

  /* ── STATS ── */
  .stats-row { display: flex; justify-content: center; gap: 5rem; flex-wrap: wrap; padding: 3rem 2.5rem; border-bottom: 1px solid var(--border); }
  .stat { text-align: center; }
  .stat-num { font-family: var(--heading); font-size: 2.8rem; font-weight: 800; color: var(--ink); line-height: 1; margin-bottom: .3rem; }
  .stat-num span { color: var(--blue); }
  .stat-label { font-size: .82rem; color: var(--ink-light); }

  /* ── FEATURES ── */
  .features-wrap { padding: 90px 2.5rem; max-width: 1100px; margin: 0 auto; }
  .section-tag { font-size: .74rem; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: .12em; margin-bottom: .7rem; }
  .section-title { font-family: var(--heading); font-weight: 800; font-size: clamp(1.9rem, 4vw, 2.8rem); color: var(--ink); line-height: 1.15; letter-spacing: -.03em; max-width: 560px; margin-bottom: .8rem; }
  .section-title em { font-style: italic; color: var(--blue); }
  .section-sub { font-size: .95rem; color: var(--ink-light); line-height: 1.7; max-width: 500px; margin-bottom: 3.5rem; }

  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .feature-card { background: var(--off-white); border: 1px solid var(--border); border-radius: 14px; padding: 1.8rem; transition: border-color .2s, transform .2s, box-shadow .2s; }
  .feature-card:hover { border-color: var(--blue-mid); transform: translateY(-3px); box-shadow: 0 8px 28px rgba(37,99,235,0.08); }
  .feature-card.featured { background: var(--blue-pale); border-color: var(--blue-soft); }
  .feature-icon { width: 44px; height: 44px; border-radius: 11px; background: #fff; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; margin-bottom: 1.2rem; }
  .feature-card.featured .feature-icon { background: var(--blue); border-color: var(--blue); }
  .feature-card h3 { font-family: var(--heading); font-size: 1.05rem; font-weight: 700; color: var(--ink); margin-bottom: .5rem; }
  .feature-card p { font-size: .87rem; color: var(--ink-mid); line-height: 1.7; }

  /* ── HOW IT WORKS ── */
  .hiw-wrap { background: var(--off-white); padding: 90px 2.5rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .hiw-inner { max-width: 1100px; margin: 0 auto; }
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 3rem; position: relative; }
  .steps::before { content: ''; position: absolute; top: 24px; left: 16.66%; right: 16.66%; height: 1px; background: var(--blue-soft); z-index: 0; }
  .step-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 2rem; position: relative; z-index: 1; transition: border-color .2s; }
  .step-card:hover { border-color: var(--blue-mid); }
  .step-num { width: 44px; height: 44px; border-radius: 11px; background: var(--blue); color: #fff; font-family: var(--heading); font-weight: 800; font-size: 1.1rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.2rem; }
  .step-card h3 { font-family: var(--heading); font-size: 1.05rem; font-weight: 700; color: var(--ink); margin-bottom: .5rem; }
  .step-card p { font-size: .87rem; color: var(--ink-mid); line-height: 1.7; }

  /* ── DETECTORS ── */
  .detectors-wrap { padding: 90px 2.5rem; max-width: 1100px; margin: 0 auto; }
  .detectors-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; margin-top: 3rem; }
  .detector-list { display: flex; flex-direction: column; gap: .8rem; }
  .detector-item { display: flex; align-items: center; justify-content: space-between; background: var(--off-white); border: 1px solid var(--border); border-radius: 10px; padding: .9rem 1.2rem; }
  .detector-item-name { font-size: .9rem; font-weight: 600; color: var(--ink); }
  .detector-badge { display: flex; align-items: center; gap: .4rem; font-size: .8rem; font-weight: 700; color: var(--blue); background: var(--blue-pale); border: 1px solid var(--blue-soft); padding: .2rem .6rem; border-radius: 100px; }
  .detectors-visual { background: var(--blue-pale); border: 1px solid var(--blue-soft); border-radius: 16px; padding: 2rem; }
  .dv-label { font-size: .75rem; font-weight: 600; color: var(--blue-deep); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 1.2rem; }
  .score-ring { width: 120px; height: 120px; margin: 0 auto 1.2rem; position: relative; }
  .score-ring svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .score-ring circle { fill: none; stroke-width: 8; }
  .score-ring .bg { stroke: var(--blue-soft); }
  .score-ring .fill { stroke: var(--blue); stroke-dasharray: 283; stroke-dashoffset: 28; stroke-linecap: round; }
  .score-num { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .score-num span { font-family: var(--heading); font-size: 2rem; font-weight: 800; color: var(--blue-deep); line-height: 1; }
  .score-num small { font-size: .65rem; color: var(--ink-light); text-transform: uppercase; letter-spacing: .05em; }
  .dv-text { text-align: center; font-size: .85rem; color: var(--blue-deep); font-weight: 500; }

  /* ── TESTIMONIALS ── */
  .testimonials-wrap { background: var(--dark); padding: 90px 2.5rem; }
  .testimonials-inner { max-width: 1100px; margin: 0 auto; }
  .testimonials-wrap .section-tag { color: var(--blue-mid); }
  .testimonials-wrap .section-title { color: #fff; }
  .big-quote { font-family: var(--heading); font-size: clamp(1.4rem, 3vw, 2rem); font-style: italic; color: rgba(255,255,255,0.9); line-height: 1.5; max-width: 780px; margin: 2.5rem 0 2rem; }
  .big-quote-author { display: flex; align-items: center; gap: 1rem; }
  .bqa-avatar { width: 46px; height: 46px; border-radius: 50%; background: var(--blue); display: flex; align-items: center; justify-content: center; font-family: var(--heading); font-weight: 700; color: #fff; font-size: .9rem; }
  .bqa-name { font-weight: 600; color: #fff; font-size: .9rem; }
  .bqa-role { font-size: .78rem; color: rgba(255,255,255,0.5); }
  .testi-mini-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.2rem; margin-top: 3.5rem; padding-top: 3.5rem; border-top: 1px solid rgba(255,255,255,0.08); }
  .testi-mini { background: var(--dark-mid); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 1.5rem; }
  .testi-stars { color: var(--blue-light); font-size: .85rem; margin-bottom: .8rem; }
  .testi-mini blockquote { font-size: .88rem; color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: 1rem; font-style: italic; }
  .testi-mini-author { display: flex; align-items: center; gap: .7rem; }
  .tma { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--heading); font-size: .75rem; font-weight: 700; color: #fff; }
  .tma-1 { background: var(--blue); }
  .tma-2 { background: var(--blue-deep); }
  .tma-3 { background: #2563eb; }
  .tma-name { font-size: .82rem; font-weight: 600; color: rgba(255,255,255,0.9); }
  .tma-role { font-size: .72rem; color: rgba(255,255,255,0.4); }

  /* ── PRICING / LIFETIME ── */
  .pricing-wrap { padding: 90px 2.5rem; max-width: 1100px; margin: 0 auto; }
  .pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 3rem; align-items: start; }
  .price-card { background: var(--off-white); border: 1px solid var(--border); border-radius: 16px; padding: 2.2rem; }
  .price-card.featured { background: var(--blue); border-color: var(--blue); }
  .price-tag-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-light); margin-bottom: .5rem; }
  .price-card.featured .price-tag-label { color: rgba(255,255,255,0.7); }
  .price-tag { font-family: var(--heading); font-size: 3.2rem; font-weight: 800; color: var(--ink); line-height: 1; margin-bottom: .3rem; }
  .price-card.featured .price-tag { color: #fff; }
  .price-tag sup { font-size: 1.4rem; vertical-align: super; }
  .price-old { font-size: .9rem; color: var(--ink-light); text-decoration: line-through; margin-bottom: .3rem; }
  .price-card.featured .price-old { color: rgba(255,255,255,0.6); }
  .price-period { font-size: .82rem; color: var(--ink-light); margin-bottom: 1.5rem; }
  .price-card.featured .price-period { color: rgba(255,255,255,0.7); }
  .price-divider { border: none; border-top: 1px solid var(--border); margin: 1.5rem 0; }
  .price-card.featured .price-divider { border-color: rgba(255,255,255,0.2); }
  .price-perks { list-style: none; display: flex; flex-direction: column; gap: .6rem; margin-bottom: 1.8rem; }
  .price-perks li { display: flex; align-items: center; gap: .6rem; font-size: .88rem; color: var(--ink-mid); }
  .price-card.featured .price-perks li { color: rgba(255,255,255,0.9); }
  .price-perks li::before { content: '✓'; color: var(--blue); font-weight: 700; flex-shrink: 0; }
  .price-card.featured .price-perks li::before { color: var(--blue-soft); }
  .btn-card { display: block; text-align: center; padding: .95rem; border-radius: 9px; font-family: var(--body); font-size: .95rem; font-weight: 700; text-decoration: none; transition: all .2s; }
  .btn-card-green { background: var(--blue); color: #fff; box-shadow: 0 4px 20px rgba(37,99,235,0.3); }
  .btn-card-green:hover { background: var(--blue-light); transform: translateY(-1px); }
  .btn-card-white { background: #fff; color: var(--blue-deep); }
  .btn-card-white:hover { background: var(--blue-soft); }
  .price-best { display: inline-block; background: #fff; color: var(--blue-deep); font-size: .72rem; font-weight: 700; padding: .25rem .7rem; border-radius: 100px; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: .05em; }

  /* ── CTA BANNER ── */
  .cta-banner { background: var(--off-white); border-top: 1px solid var(--border); padding: 90px 2.5rem; }
  .cta-inner { max-width: 700px; margin: 0 auto; text-align: center; }
  .cta-inner h2 { font-family: var(--heading); font-weight: 800; font-size: clamp(2rem, 4.5vw, 3.2rem); color: var(--ink); line-height: 1.1; letter-spacing: -.03em; margin-bottom: 1.2rem; }
  .cta-inner h2 em { font-style: italic; color: var(--blue); }
  .cta-inner p { font-size: 1rem; color: var(--ink-light); margin-bottom: 2.5rem; }
  .cta-fine { font-size: .78rem; color: var(--ink-light); margin-top: 1rem; }

  /* ── FOOTER ── */
  footer { background: var(--dark); padding: 3.5rem 2.5rem 2rem; }
  .footer-top { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 2rem; margin-bottom: 2.5rem; }
  .footer-brand { max-width: 260px; }
  .footer-logo { font-family: var(--heading); font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: .8rem; display: flex; align-items: center; gap: .4rem; }
  .footer-logo-dot { width: 7px; height: 7px; background: var(--blue); border-radius: 50%; display: inline-block; }
